rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Usuários: qualquer usuário logado pode ler, apenas próprio usuário pode editar
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Carros: qualquer um pode ler, apenas dono pode criar/editar/deletar
    match /cars/{carId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
    }
    
    // Avaliações: qualquer um pode ler, apenas usuário logado pode criar/atualizar
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}